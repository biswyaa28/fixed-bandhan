{
  "name": "bandhan-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "build:demo": "NEXT_PUBLIC_DEMO_MODE=true npm run build",
    "build:static": "NEXT_PUBLIC_DEMO_MODE=true next build && next export",
    "build:firebase": "FIREBASE_STATIC=true NEXT_PUBLIC_DEMO_MODE=false next build",
    "build:firebase:demo": "FIREBASE_STATIC=true NEXT_PUBLIC_DEMO_MODE=true next build",
    "deploy:firebase": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:firebase:demo": "npm run build:firebase:demo && firebase deploy --only hosting",
    "deploy:firebase:staging": "npm run build:firebase && firebase deploy --only hosting -P staging",
    "deploy:firebase:preview": "npm run build:firebase:demo && firebase hosting:channel:deploy preview --expires 7d",
    "deploy:firebase:all": "npm run build:firebase && firebase deploy",
    "deploy:firebase:rollback": "firebase hosting:rollback",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "health:check:remote": "curl -f https://bandhan-ai-demo.vercel.app/api/health || exit 1",
    "health:check:firebase": "curl -f https://bandhan-ai-prod.web.app/api/health || exit 1",
    "demo": "NEXT_PUBLIC_DEMO_MODE=true npm run dev",
    "demo:build": "NEXT_PUBLIC_DEMO_MODE=true npm run build",
    "demo:deploy": "npm run build:demo && npm run deploy:vercel",
    "seed": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 npx tsx lib/firebase/seed.ts",
    "seed:prod": "npx tsx lib/firebase/seed.ts",
    "firestore:deploy": "firebase deploy --only firestore:rules,firestore:indexes",
    "emulators": "firebase emulators:start",
    "emulators:hosting": "npm run build:firebase:demo && firebase emulators:start --only hosting",
    "predeploy:check": "npm run lint && npm run type-check && npm run build:firebase",
    "analyze": "ANALYZE=true next build",
    "analyze:firebase": "ANALYZE=true FIREBASE_STATIC=true next build",
    "pwa:icons": "node scripts/generate-icons.mjs",
    "pwa:icons:build": "node scripts/generate-icons.mjs && npm run build",
    "security:audit": "npm audit --production --audit-level=high",
    "security:check": "npm audit --production --audit-level=high && npm run lint && npm run type-check",
    "security:headers": "echo 'Test at: https://securityheaders.com/?q=https://bandhan.ai'",
    "security:observatory": "echo 'Test at: https://observatory.mozilla.org/analyze/bandhan.ai'",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "dx:check": "npm run lint && npm run type-check && npm run format -- --check",
    "dx:fix": "npm run lint -- --fix && npm run format",
    "dx:clean": "rm -rf .next out node_modules/.cache",
    "dx:fresh": "rm -rf node_modules .next out && npm install",
    "dx:ports": "lsof -i :3000 -i :4000 -i :4001 -i :8080 -i :9099 || echo 'No port conflicts found'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=10",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix --max-warnings=10",
      "prettier --write"
    ],
    "*.{json,md,mdx,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@tanstack/react-query": "^5.51.21",
    "axios": "^1.7.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "firebase": "^10.12.5",
    "framer-motion": "^11.3.19",
    "immer": "^10.1.1",
    "libphonenumber-js": "^1.11.4",
    "lucide-react": "^0.414.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "next-pwa": "^5.6.0",
    "razorpay": "^2.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.52.2",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.2.1",
    "react-image-crop": "^11.0.5",
    "react-intersection-observer": "^9.13.0",
    "react-phone-number-input": "^3.4.3",
    "react-use": "^17.5.0",
    "sharp": "^0.33.4",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.4.0",
    "typescript": "^5.5.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@tanstack/react-query-devtools": "^5.51.21",
    "firebase-admin": "^12.3.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "autoprefixer": "^10.4.19",
    "crypto-browserify": "^3.12.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "msw": "^2.12.10",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.7"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}

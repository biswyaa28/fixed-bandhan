# ══════════════════════════════════════════════════════════════════════════════
# Bandhan AI — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
#
# SETUP:
#   cp .env.local.example .env.local
#   Then fill in values from each service's dashboard.
#
# RULES:
#   • NEXT_PUBLIC_ vars are exposed to the browser — safe for Firebase keys,
#     but NEVER put server secrets (private keys, DB passwords) here.
#   • Server-only vars (no NEXT_PUBLIC_ prefix) are only available in
#     API routes, middleware, and getServerSideProps.
#   • NEVER commit .env.local to Git (it's in .gitignore).
#
# ══════════════════════════════════════════════════════════════════════════════


# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Bandhan AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# Set to "true" to use mock services (no real Firebase, no real backend).
# The demo flag is checked by AuthContext and lib/firebase/config.ts.
NEXT_PUBLIC_DEMO_MODE=false


# ─── Firebase (Client — browser-safe) ────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your Apps
# These ARE safe in the client bundle. Security is enforced by Firestore/
# Storage rules and Auth settings, NOT by hiding the API key.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Set to "true" to connect to local Firebase emulators instead of production.
# Run `firebase emulators:start` first (ports in firebase.json).
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# VAPID key for Firebase Cloud Messaging (push notifications).
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=



# ─── Umami Analytics (Self-hosted, Privacy-first) ────────────────────────────
# Deploy Umami: docker compose up -d (see docker-compose.yml)
# Or use the Railway template: https://railway.app/template/umami
#
# 1. Open your Umami dashboard
# 2. Add website: name="Bandhan AI", domain="bandhan.ai"
# 3. Copy the Website ID (UUID) below
# 4. Set the host URL below
#
# ALL analytics data stays on YOUR servers. NO third-party tracking.
# Region: Railway Mumbai (ap-south-1) for DPDP Act data localisation.

NEXT_PUBLIC_UMAMI_HOST=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=


# ─── Build Flags ──────────────────────────────────────────────────────────────
# Set to "true" when building for Firebase Hosting (static export).
# This triggers output: "export" in next.config.js.
# Usage: FIREBASE_STATIC=true npm run build
FIREBASE_STATIC=false


# ─── Error Tracking (Sentry — optional) ──────────────────────────────────────
# Dashboard: https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# ─── Firebase Admin (Server-only — NEVER prefix with NEXT_PUBLIC_) ───────────
# Get these from: Firebase Console → Project Settings → Service Accounts
# Click "Generate new private key" and copy the values.
# The private key contains \n literals — paste the raw JSON value.

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=


# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=


# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Connection string format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=
DIRECT_URL=


# ─── Razorpay (India Payment Gateway) ────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=


# ─── AWS S3 (Mumbai — ap-south-1) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=bandhan-media


# ─── CDN / Media ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_MEDIA_URL=


# ─── DigiLocker (Aadhaar KYC) ────────────────────────────────────────────────
# Register at: https://partners.digilocker.gov.in
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:3000/api/auth/digilocker


# ─── MSG91 (SMS OTP fallback when Firebase Phone Auth quota is exceeded) ─────
# Dashboard: https://msg91.com
MSG91_AUTH_KEY=
MSG91_SENDER_ID=BNDHAN
MSG91_TEMPLATE_ID=


# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_SECRET_KEY=

# ─── Socket.io (Real-time Chat) ──────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001


# ─── KMS Encryption ──────────────────────────────────────────────────────────
KMS_KEY_ARN=
ENCRYPTION_SECRET=

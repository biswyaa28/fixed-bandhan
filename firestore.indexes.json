      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "city", "order": "ASCENDING" },
        { "fieldPath": "gender", "order": "ASCENDING" },
        { "fieldPath": "age", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "users: Discovery feed — filter by diet + intent",

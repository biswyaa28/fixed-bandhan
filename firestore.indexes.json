  "fieldOverrides": [
    {
      "_comment": "Exempt bio text from single-field indexing to save costs",
      "collectionGroup": "users",
      "fieldPath": "bio",
      "indexes": []
    },
    {
      "_comment": "Exempt message content from indexing",
      "collectionGroup": "messages",
      "fieldPath": "content",
      "indexes": []
    },
    {
      "_comment": "Exempt success story quotes from indexing",
      "collectionGroup": "successStories",
      "fieldPath": "quoteEn",
      "indexes": []
    },
    {
      "_comment": "Exempt success story Hindi quotes from indexing",
      "collectionGroup": "successStories",
      "fieldPath": "quoteHi",
